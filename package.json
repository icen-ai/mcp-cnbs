{
  "name": "mcp-cnbs",
  "version": "1.1.0",
  "description": "MCP server for China National Bureau of Statistics (CNBS) data access",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "mcp-cnbs": "dist/index.js"
  },
  "files": [
    "dist",
    "llms.txt",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "pnpm": {
    "ignoredBuiltDependencies": ["sharp"]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js --port 12345",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy"
  },
  "keywords": [
    "mcp",
    "statistics",
    "china",
    "nbs",
    "cnbs",
    "modelcontextprotocol",
    "gdp",
    "cpi",
    "population"
  ],
  "author": "J.K.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/icen-ai/mcp-cnbs.git"
  },
  "bugs": {
    "url": "https://github.com/icen-ai/mcp-cnbs/issues"
  },
  "homepage": "https://github.com/icen-ai/mcp-cnbs#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.8.4",
    "chart.js": "^4.4.0",
    "commander": "^14.0.0",
    "d3": "^7.9.0",
    "echarts": "^5.4.3",
    "lodash": "^4.17.21",
    "mathjs": "^12.0.0",
    "mcp-http-server": "^1.1.5",
    "simple-statistics": "^7.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260404.1",
    "@types/d3": "^7.4.3",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.19.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.3.0",
    "wrangler": "^4.81.1"
  }
}
